<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_LAYOUT_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/main_IMG_logo"
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:layout_marginBottom="18dp"
        android:contentDescription="Road Game logo"
        android:scaleType="fitCenter"
        android:src="@drawable/road_game_logo" />

    <LinearLayout
        android:id="@+id/main_LAYOUT_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layoutDirection="ltr"
        android:layout_marginBottom="36dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/main_TXT_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Road Game"
            android:textColor="#263238"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/main_TXT_hw"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="(HW2)"
            android:textColor="#455A64"
            android:textSize="18sp"
            android:textStyle="normal" />

    </LinearLayout>

    <Button
        android:id="@+id/main_BTN_slow"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="14dp"
        android:text="Buttons Mode - Slow"
        android:textAllCaps="false"
        android:textSize="18sp" />

    <Button
        android:id="@+id/main_BTN_fast"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="14dp"
        android:text="Buttons Mode - Fast"
        android:textAllCaps="false"
        android:textSize="18sp" />

    <Button
        android:id="@+id/main_BTN_sensors"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="14dp"
        android:text="Sensor Mode"
        android:textAllCaps="false"
        android:textSize="18sp" />

    <Button
        android:id="@+id/main_BTN_records"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="High Scores"
        android:textAllCaps="false"
        android:textSize="18sp" />

</LinearLayout>